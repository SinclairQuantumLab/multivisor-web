; Supervisor config file for program(s)
; copy this file into /etc/supervisor/conf.d/ folder

[program:multivisor-web]
command=/home/imaq-pi01/Projects/multivisor-web/Startup_bash
environment=PYTHONUNBUFFERED=1 ; let stdout logged in real time for python app
user=imaq-pi01
autostart=true
startsecs=5
stdout_logfile=/etc/supervisor/logs/multivisor-web_out.log
stderr_logfile=/etc/supervisor/logs/multivisor-web_err.log
